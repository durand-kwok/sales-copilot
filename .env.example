# Slack app credentials (Socket Mode) — from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key
CLAUDE_MODEL=claude-sonnet-5

# Logging
LOG_LEVEL=info

# Snowflake (AIRE_DATA.WORKFORCE_ANALYTICS)
SNOWFLAKE_ACCOUNT=your-account-identifier
SNOWFLAKE_USERNAME=your-username
SNOWFLAKE_WAREHOUSE=your-warehouse

# Key-pair auth (recommended default)
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=only-if-your-key-is-encrypted

# Password auth (local-dev fallback only — less secure than key-pair)
# SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE
# SNOWFLAKE_PASSWORD=your-password

# Optional overrides (defaults shown)
# SNOWFLAKE_DATABASE=AIRE_DATA
# SNOWFLAKE_SCHEMA=WORKFORCE_ANALYTICS
# SNOWFLAKE_ROLE=your-role
